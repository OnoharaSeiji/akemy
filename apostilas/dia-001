<script>
function answer(btn){
  const ex = btn.closest('.exercise');
  ex.querySelectorAll('.option').forEach(b=>b.classList.remove('correct','wrong'));
  const ok = btn.dataset.correct === 'true';
  btn.classList.add(ok ? 'correct' : 'wrong');
  ex.querySelectorAll('.option').forEach(b=>{ if(b!==btn && b.dataset.correct==='true') b.classList.add('correct'); });
  const fb = ex.querySelector('.feedback');
  fb.className = 'feedback ' + (ok ? 'ok' : 'bad');
  fb.innerHTML = '<strong>' + (ok ? 'Acertou.' : 'Errou.') + '</strong> ' + btn.dataset.exp;
  fb.style.display = 'block';
}
(function(){
  const pageKey = 'akemy-' + document.body.dataset.page;
  const boxes = document.querySelectorAll('.ck input[type="checkbox"]');
  const saved = JSON.parse(localStorage.getItem(pageKey) || '[]');
  boxes.forEach((box, i) => {
    box.checked = !!saved[i];
    box.addEventListener('change', () => {
      localStorage.setItem(pageKey, JSON.stringify([...boxes].map(x => x.checked)));
    });
  });
})();
</script>
